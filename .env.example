# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ops
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Per-service DB passwords (used by docker/postgres/init.sh)
AUTOAGENT_DB_PASSWORD=CHANGE_ME_autoagent_db
CUA_DB_PASSWORD=CHANGE_ME_cua_db
TREND_RADAR_DB_PASSWORD=CHANGE_ME_radar_db
SYNAPSE_DB_PASSWORD=CHANGE_ME_synapse_db

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password

# ── Anthropic / AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...               # optional: ruflo multi-provider routing

# ── autoagent ─────────────────────────────────────────────────────────────────
AUTOAGENT_SECRET=CHANGE_ME_jwt_secret_min32chars

# ── ruflo ─────────────────────────────────────────────────────────────────────
RUFLO_ENVIRONMENT=production
# RUFLO_MEMORY_PATH=/srv/godoman/ruflo-memory

# ── cua ───────────────────────────────────────────────────────────────────────
CUA_SECRET=CHANGE_ME_jwt_secret_min32chars

# ── trend-radar ───────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_min32chars
NEXTAUTH_URL=https://radar.godoman.net
ADMIN_EMAILS=ops@godoman.net
CRON_SECRET=CHANGE_ME_cron_secret_min32chars

# Optional: AI summarisation for trend digests (Vercel AI SDK)
# If unset, trend-radar runs without LLM summaries (still scrapes + clusters)
# AI_GATEWAY_API_KEY=

# Optional: X/Twitter API (for x-studio content pipeline)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin

# ── Caddy / TLS ───────────────────────────────────────────────────────────────
ACME_EMAIL=ops@godoman.net
DOMAIN=godoman.net
